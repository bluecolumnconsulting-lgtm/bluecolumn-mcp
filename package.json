  "description": "MCP server for BlueColumn — persistent semantic memory API for AI agents. Give any MCP-compatible agent the ability to remember, recall, and store observations across sessions.",
  "main": "dist/index.js",
  "bin": {
    "bluecolumn-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts"
  },
  "keywords": [
    "mcp",
    "ai",
    "agents",
    "memory",
    "bluecolumn",
    "vector",
    "rag",
    "pinecone",
    "langchain",
    "claude"
  ],
  "author": "BlueColumn <hello@bluecolumn.ai>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bluecolumn/bluecolumn-mcp"
  },
  "homepage": "https://bluecolumn.ai"
}
